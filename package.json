{
  "name": "Zetamac",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "./",
  "main": "main.cjs",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "set ELECTRON_START_URL=http://localhost:5173 && electron .",
    "package-win": "npm run build && electron-builder --win -c.extraMetadata.main=main.cjs"
  },
  "build": {
    "appId": "com.zetamac.arithmetic",
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
